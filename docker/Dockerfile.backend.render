FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY backend/package*.json ./backend/

# Install dependencies
RUN npm install
RUN cd backend && npm install

# Copy backend source
COPY backend/tsconfig.json ./backend/
COPY backend/src ./backend/src

# Build TypeScript
RUN cd backend && npm run build

EXPOSE 10000

WORKDIR /app/backend

CMD ["npm", "start"]
